# Apache SPA fallback: serve index.html for any path that isn't a real file,
# so refreshing or directly opening a URL doesn't 404.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Allow direct access to real files and directories (assets, images, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else falls back to index.html
  RewriteRule ^ index.html [L]
</IfModule>
